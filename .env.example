# Copy to .env and fill in. .env is gitignored.
# All Tier 2 actions check ALLOWED_USERS before executing.

# --- Identity ---
USER_NAME=                       # injected into docs/00-agent-identity.md at agent load time

# --- Chat platform ---
CHAT_PLATFORM=telegram           # "telegram" | "teams" — selects which adapter to load
ALLOWED_USERS=                   # comma-separated platform-specific user IDs:
                                 #   telegram → numeric Telegram user IDs (as strings)
                                 #   teams    → AAD object IDs from the user's Teams profile

# --- Telegram (when CHAT_PLATFORM=telegram) ---
TELEGRAM_BOT_TOKEN=              # from @BotFather
TELEGRAM_WEBHOOK_URL=            # https://<your-host>/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=         # any random string; Telegram echoes it back as a header

# --- Microsoft Teams (when CHAT_PLATFORM=teams) ---
# Pre-deploy setup (operator work, not code):
#   1. Azure portal → "Azure Bot" resource → record MicrosoftAppId
#   2. Add Microsoft Teams channel to the bot
#   3. Generate a client secret on the bot's AAD app registration
#   4. Set the bot's messaging endpoint to https://<your-host>/api/messages
#   5. Either sideload a Teams app manifest pointing at this bot or publish to your tenant
#   6. Have the target user DM the bot once so we capture their ConversationReference
#      (Teams won't let the bot DM strangers; the first user-initiated message unlocks proactive sends)
TEAMS_APP_ID=                    # MicrosoftAppId from the Azure Bot resource
TEAMS_APP_PASSWORD=              # client secret on the same AAD app registration
# PORT defaults to 3978 for Teams (Bot Framework convention), 8080 for Telegram.

# --- Claude (W1, via ASUS-issued Azure endpoint) ---
ANTHROPIC_API_KEY=               # competition-issued key (編號 15)
ANTHROPIC_BASE_URL=              # ASUS Azure endpoint, e.g. https://.../anthropic
ANTHROPIC_MODEL=claude-opus-4-6-2026V2

# --- Alternative auth: Microsoft Azure Foundry (when ASUS endpoint supports it) ---
# Per https://code.claude.com/docs/zh-TW/agent-sdk/ §setup, the Agent SDK can
# auth to a first-party Azure Foundry-hosted Claude deployment without us
# managing an ANTHROPIC_API_KEY. Set this to "1" to opt in — the SDK will then
# pull AAD credentials from the Azure CLI / Managed Identity instead. ASUS
# endpoints today are reachable via the BASE_URL+key path above; this is
# documented for when/if ops switches to Foundry-native auth.
# CLAUDE_CODE_USE_FOUNDRY=
# Other supported providers (uncomment one if migrating off the ASUS endpoint):
# CLAUDE_CODE_USE_BEDROCK=1         # Amazon Bedrock + AWS creds
# CLAUDE_CODE_USE_ANTHROPIC_AWS=1   # Claude Platform on AWS + ANTHROPIC_AWS_WORKSPACE_ID
# CLAUDE_CODE_USE_VERTEX=1          # Google Vertex AI + GCP creds

# --- Kimi K2.5 (W2, bulk routing) ---
KIMI_API_KEY=
KIMI_BASE_URL=

# --- OpenAI GPT-5.4 (fallback only) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Gmail (W2, IMAP + app password, NOT OAuth) ---
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_SMTP_HOST=smtp.gmail.com

# --- Bluesky (W3) ---
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# --- Operations ---
LOG_LEVEL=INFO
COST_BUDGET_USD=100              # 50/80/100/120% alerts trigger off this
